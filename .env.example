# Gmail SMTP sender address
EMAIL_USER=your-gmail@gmail.com

# Gmail app password (16-char, generated in Google account security)
EMAIL_PASS=your-16-char-app-password

# Who receives contact form submissions
CONTACT_RECIPIENT_EMAIL=contact@tecsteer.com

# Public site URL — used for CSRF check and metadata
NEXT_PUBLIC_SITE_URL=https://tecsteer.com

# Optional: Upstash Redis for rate limiting (leave blank to skip in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
